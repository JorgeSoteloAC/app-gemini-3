{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An electronic product available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the product." },
        "description": { "type": "string", "description": "Detailed product description." },
        "price": { "type": "number", "description": "Price in USD." },
        "category": { "type": "string", "description": "Category ID or name." },
        "imageUrl": { "type": "string", "description": "URL to product image." },
        "stock": { "type": "integer", "description": "Number of units in stock." },
        "specs": { "type": "object", "description": "Key-value pairs of technical specifications." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "imageUrl"]
    },
    "Category": {
      "title": "Category",
      "description": "A group of related products.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string", "description": "Lucide icon name." },
        "order": { "type": "integer" }
      },
      "required": ["name"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "A product in a user's shopping cart.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "integer" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A completed transaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Public catalog of electronics."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories."
    },
    "/users/{userId}/cart/{itemId}": {
      "schema": "CartItem",
      "description": "A user's private shopping cart."
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": "Order",
      "description": "A user's order history."
    }
  }
}
